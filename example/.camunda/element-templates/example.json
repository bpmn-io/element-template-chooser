  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "name": "Azure Blob Storage Connector",
    "id": "io.camunda.connectors.AzureBlobStorage.v1",
    "version": 1,
    "description": "Manage Azure Blob Storage containers and blobs",
    "appliesTo": [
      "bpmn:ServiceTask"
    ],
    "category": {
      "id": "connectors",
      "name": "Connectors"
    },
    "keywords": [
      "azure",
      "blob storage"
    ],
    "properties": [
      {
        "type": "Hidden",
        "value": "io.camunda:azure-blob-storage:1",
        "binding": {
          "type": "zeebe:taskDefinition",
          "property": "type"
        }
      },
      {
        "type": "Hidden",
        "binding": {
          "type": "zeebe:input",
          "name": "operationGroup"
        }
      },
      {
        "type": "Hidden",
        "binding": {
          "type": "zeebe:input",
          "name": "operation"
        }
      },
      {
        "label": "Account name",
        "type": "String",
        "binding": {
          "type": "zeebe:input",
          "name": "accountName"
        }
      },
      {
        "label": "Container name",
        "type": "String",
        "binding": {
          "type": "zeebe:input",
          "name": "containerName"
        }
      },
      {
        "label": "Blob name",
        "type": "String",
        "optional": true,
        "binding": {
          "type": "zeebe:input",
          "name": "blobName"
        }
      }
    ],
    "steps": [
      {
        "name": "Containers",
        "description": "Manage Azure storage containers",
        "steps": [
          {
            "name": "Create container",
            "description": "Create a new container in the storage account",
            "keywords": [
              "create container",
              "new container"
            ],
            "presetId": "createContainer"
          },
          {
            "name": "Delete container",
